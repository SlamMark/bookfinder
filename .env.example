# ── BookFinder Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Z-Library credentials (required for Z-Library searches)
ZLIB_EMAIL=tu_email@ejemplo.com
ZLIB_PASSWORD=tu_contraseña

# Download directory (default: ./downloads)
# DOWNLOAD_DIR=/ruta/a/tus/descargas

# Libgen mirror extension: li, bz, gs (default: li)
# LIBGEN_MIRROR=li

# Default language code: es, en, fr, de, it, pt … (empty = any)
# DEFAULT_LANG=es

# Max results to show in CLI (default: 15)
# MAX_RESULTS=15

# Telegram bot token (required for Phase 2 bot)
TELEGRAM_TOKEN=tu_token_de_botfather

# Max result buttons shown in bot (default: 8)
# BOT_MAX_RESULTS=8
