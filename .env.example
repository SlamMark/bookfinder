# ── BookFinder Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Z-Library credentials (required for Z-Library searches)
ZLIB_EMAIL=tu_email@ejemplo.com
ZLIB_PASSWORD=tu_contraseña

# Download directory (default: ./downloads)
# DOWNLOAD_DIR=/ruta/a/tus/descargas

# Libgen mirror extension: li, bz, gs (default: li)
# LIBGEN_MIRROR=li

# Default language code: es, en, fr, de, it, pt … (empty = any)
# DEFAULT_LANG=es

# Max results to show in CLI (default: 15)
# MAX_RESULTS=15

# Telegram bot token (required for Phase 2 bot)
TELEGRAM_TOKEN=tu_token_de_botfather

# Max result buttons shown in bot (default: 8)
# BOT_MAX_RESULTS=8

# ── SMTP — Gmail App Password (for Kindle email sending) ──────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to: Google Account → Security → App Passwords
# 3. Create an app password → copy the 16-char code
# 4. In Amazon: Manage Content → Preferences → Approved Personal Document E-mail List
#    → add your SMTP_USER address as approved sender
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=BookFinder <tu_cuenta@gmail.com>
